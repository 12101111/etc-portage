From 8d8ae7a760c25296e8037748313feb59b511774d Mon Sep 17 00:00:00 2001
From: nataliakokoromyti <nataliakokoromyti@gmail.com>
Date: Mon, 2 Feb 2026 16:55:13 -0800
Subject: [PATCH] [LoongArch] Fix fptoui.sat miscompilation with NaN inputs

---
 .../LoongArch/LoongArchISelLowering.cpp       | 16 ++++++-------
 llvm/test/CodeGen/LoongArch/fptoui-sat-nan.ll | 24 +++++++++++++++++++
 2 files changed, 32 insertions(+), 8 deletions(-)
 create mode 100644 llvm/test/CodeGen/LoongArch/fptoui-sat-nan.ll

diff --git a/llvm/lib/Target/LoongArch/LoongArchISelLowering.cpp b/llvm/lib/Target/LoongArch/LoongArchISelLowering.cpp
index 486500e5f3f2d..eb1fed1367de6 100644
--- a/llvm/lib/Target/LoongArch/LoongArchISelLowering.cpp
+++ b/llvm/lib/Target/LoongArch/LoongArchISelLowering.cpp
@@ -225,9 +225,9 @@ LoongArchTargetLowering::LoongArchTargetLowering(const TargetMachine &TM,
     setOperationAction(ISD::BR_CC, MVT::f32, Expand);
     setOperationAction(ISD::FMA, MVT::f32, Legal);
     setOperationAction(ISD::FMINNUM_IEEE, MVT::f32, Legal);
-    setOperationAction(ISD::FMINNUM, MVT::f32, Legal);
+    setOperationAction(ISD::FMINNUM, MVT::f32, Expand);
     setOperationAction(ISD::FMAXNUM_IEEE, MVT::f32, Legal);
-    setOperationAction(ISD::FMAXNUM, MVT::f32, Legal);
+    setOperationAction(ISD::FMAXNUM, MVT::f32, Expand);
     setOperationAction(ISD::FCANONICALIZE, MVT::f32, Legal);
     setOperationAction(ISD::STRICT_FSETCCS, MVT::f32, Legal);
     setOperationAction(ISD::STRICT_FSETCC, MVT::f32, Legal);
@@ -275,10 +275,10 @@ LoongArchTargetLowering::LoongArchTargetLowering(const TargetMachine &TM,
     setOperationAction(ISD::STRICT_FSETCC, MVT::f64, Legal);
     setOperationAction(ISD::FMA, MVT::f64, Legal);
     setOperationAction(ISD::FMINNUM_IEEE, MVT::f64, Legal);
-    setOperationAction(ISD::FMINNUM, MVT::f64, Legal);
+    setOperationAction(ISD::FMINNUM, MVT::f64, Expand);
     setOperationAction(ISD::FMAXNUM_IEEE, MVT::f64, Legal);
     setOperationAction(ISD::FCANONICALIZE, MVT::f64, Legal);
-    setOperationAction(ISD::FMAXNUM, MVT::f64, Legal);
+    setOperationAction(ISD::FMAXNUM, MVT::f64, Expand);
     setOperationAction(ISD::IS_FPCLASS, MVT::f64, Legal);
     setOperationAction(ISD::FSIN, MVT::f64, Expand);
     setOperationAction(ISD::FCOS, MVT::f64, Expand);
@@ -373,8 +373,8 @@ LoongArchTargetLowering::LoongArchTargetLowering(const TargetMachine &TM,
       setOperationAction(ISD::FFLOOR, VT, Legal);
       setOperationAction(ISD::FTRUNC, VT, Legal);
       setOperationAction(ISD::FROUNDEVEN, VT, Legal);
-      setOperationAction(ISD::FMINNUM, VT, Legal);
-      setOperationAction(ISD::FMAXNUM, VT, Legal);
+      setOperationAction(ISD::FMINNUM, VT, Expand);
+      setOperationAction(ISD::FMAXNUM, VT, Expand);
     }
     setOperationAction(ISD::CTPOP, GRLenVT, Legal);
     setOperationAction(ISD::FCEIL, {MVT::f32, MVT::f64}, Legal);
@@ -462,8 +462,8 @@ LoongArchTargetLowering::LoongArchTargetLowering(const TargetMachine &TM,
       setOperationAction(ISD::FFLOOR, VT, Legal);
       setOperationAction(ISD::FTRUNC, VT, Legal);
       setOperationAction(ISD::FROUNDEVEN, VT, Legal);
-      setOperationAction(ISD::FMINNUM, VT, Legal);
-      setOperationAction(ISD::FMAXNUM, VT, Legal);
+      setOperationAction(ISD::FMINNUM, VT, Expand);
+      setOperationAction(ISD::FMAXNUM, VT, Expand);
     }
   }
 
diff --git a/llvm/test/CodeGen/LoongArch/fptoui-sat-nan.ll b/llvm/test/CodeGen/LoongArch/fptoui-sat-nan.ll
new file mode 100644
index 0000000000000..be6adfca65c77
--- /dev/null
+++ b/llvm/test/CodeGen/LoongArch/fptoui-sat-nan.ll
@@ -0,0 +1,24 @@
+; NOTE: Assertions have been autogenerated by utils/update_llc_test_checks.py UTC_ARGS: --version 6
+; RUN: llc --mtriple=loongarch64 < %s | FileCheck %s
+
+define i32 @fptoui_sat_f64_nan_canonical() {
+; CHECK-LABEL: fptoui_sat_f64_nan_canonical:
+; CHECK:       # %bb.0:
+; CHECK-NEXT:    move $a0, $zero
+; CHECK-NEXT:    ret
+  %nan = bitcast i64 9221120237041090560 to double
+  %result = call i32 @llvm.fptoui.sat.i32.f64(double %nan)
+  ret i32 %result
+}
+
+define i32 @fptoui_sat_f64_nan_payload() {
+; CHECK-LABEL: fptoui_sat_f64_nan_payload:
+; CHECK:       # %bb.0:
+; CHECK-NEXT:    move $a0, $zero
+; CHECK-NEXT:    ret
+  %nan = bitcast i64 9219994337134247936 to double
+  %result = call i32 @llvm.fptoui.sat.i32.f64(double %nan)
+  ret i32 %result
+}
+
+declare i32 @llvm.fptoui.sat.i32.f64(double)
